{
    "rules": [
        {
            "category": "Images",
            "extensions": [".jpg", ".jpeg", ".png", ".gif", ".svg"],
            "target_dir": "Media/Images"
        },
        {
            "category": "Documents",
            "extensions": [".pdf", ".docx", ".txt", ".xlsx", ".pptx"],
            "target_dir": "Work/Documents"
        },
        {
            "category": "Scripts",
            "extensions": [".py", ".js", ".html", ".css", ".cpp"],
            "target_dir": "Development/Code"
        },
        {
            "category": "Compressed",
            "extensions": [".zip", ".rar", ".7z", ".tar"],
            "target_dir": "Archives"
        }
    ],
    "default_folder": "Others"
}